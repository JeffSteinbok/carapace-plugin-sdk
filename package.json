{
  "name": "carapace-plugin-sdk",
  "version": "1.0.5",
  "description": "🦞🐚 SDK for building OpenClaw plugins — types, helpers, CLI generation",
  "repository": {
    "type": "git",
    "url": "https://github.com/JeffSteinbok/carapace-plugin-sdk"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./tsup": {
      "import": "./dist/tsup.plugin.config.js"
    },
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "bin": {
    "carapace-generate-cli": "./dist/generate-cli.js"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "tsconfig.base.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "sdk",
    "carapace",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.3.0",
    "typescript": "^5.7",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  }
}
